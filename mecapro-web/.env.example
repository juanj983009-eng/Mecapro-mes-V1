# ================================================================
# Meca-PRO MES — Plantilla de Variables de Entorno
# ================================================================
# Copia este archivo como .env para desarrollo local:
#   cp .env.example .env
#
# Para producción (Vercel / Railway):
#   Configurar estas variables directamente en el panel del proveedor.
#   NUNCA incluir .env con valores reales en el repositorio.
# ================================================================

# URL base del backend API (incluye el prefijo /api)
# — Desarrollo local:
VITE_API_URL=http://localhost:8081/api
# — Producción Railway (configurar en panel de Vercel → Settings → Environment Variables):
# VITE_API_URL=https://mecapro-mes-v1-production.up.railway.app/api
#
# NOTA: La URL DEBE terminar en /api porque los controladores del backend
# usan @RequestMapping("/api/..."). NO añadir server.servlet.context-path=/api
# en application.properties — generaría rutas duplicadas (/api/api/...).
